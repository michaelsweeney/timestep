{
  "name": "timestep",
  "productName": "timestep",
  "version": "2.0.0",
  "description": "SQL-based Timeseries Viewer for EnergyPlus",
  "scripts": {
    "build": "concurrently \"yarn build-main\" \"yarn build-renderer\"",
    "build-main": "cross-env NODE_ENV=production webpack --config ./configs/webpack.config.main.prod.js",
    "build-renderer": "cross-env NODE_ENV=production webpack --config ./configs/webpack.config.renderer.prod.js",
    "build-web": "rm -rf app/dist-web && cross-env NODE_ENV=production webpack --config ./configs/webpack.config.web.prod.js && cp app/web.html app/dist-web/index.html",
    "start-web": "python3 -m http.server 8080 --directory app/dist-web",
    "web": "yarn build-web && yarn start-web",
    "smoke-web": "node scripts/web-smoke.mjs",
    "test-serve": "node --import tsx --test \"app/serve/**/*.test.ts\"",
    "ts-serve": "tsc -p tsconfig.serve.json",
    "build-serve": "rimraf app/dist-serve && cross-env NODE_ENV=production webpack --config ./configs/webpack.config.serve.prod.js && node -e \"require('fs').copyFileSync('app/serve.html','app/dist-serve/index.html')\"",
    "serve": "yarn build-serve && node --import tsx app/serve/start.ts",
    "smoke-serve": "node --import tsx scripts/serve-smoke.mjs",
    "dev": "cross-env START_HOT=1 node -r @babel/register ./internals/scripts/CheckPortInUse.js && cross-env START_HOT=1 yarn start-renderer-dev",
    "electron-rebuild": "electron-rebuild --parallel --force --types prod,dev,optional --module-dir app",
    "ts": "tsc",
    "eplus-matrix": "node scripts/eplus-matrix.mjs",
    "smoke-ui": "node scripts/ui-smoke.mjs",
    "lint": "cross-env NODE_ENV=development eslint . --cache --ext .js,.jsx,.ts,.tsx",
    "lint-fix": "yarn --silent lint --fix; exit 0",
    "lint-styles": "stylelint --ignore-path .eslintignore '**/*.*(css|scss)' --syntax scss",
    "lint-styles-fix": "yarn --silent lint-styles --fix; exit 0",
    "package": "yarn build && electron-builder build --publish never",
    "package-all": "yarn build && electron-builder build -mwl",
    "package-mw": "yarn build && electron-builder build -mw",
    "package-ci": "yarn postinstall && yarn build && electron-builder --publish always",
    "package-mac": "yarn build && electron-builder build --mac",
    "package-linux": "yarn build && electron-builder build --linux",
    "package-win": "yarn build && electron-builder build --win --x64",
    "postinstall": "node -r @babel/register internals/scripts/CheckNativeDep.js && electron-builder install-app-deps",
    "postlint-fix": "prettier --ignore-path .eslintignore --single-quote --write '**/*.{js,jsx,json,html,css,less,scss,yml}'",
    "postlint-styles-fix": "prettier --ignore-path .eslintignore --single-quote --write '**/*.{css,scss}'",
    "preinstall": "node ./internals/scripts/CheckYarn.js",
    "prestart": "yarn build",
    "start": "cross-env NODE_ENV=production electron ./app/main.prod.js",
    "start-main-dev": "cross-env START_HOT=1 NODE_ENV=development electron --ozone-platform=x11 ./app/main.dev.cjs",
    "start-renderer-dev": "cross-env NODE_ENV=development webpack serve --config configs/webpack.config.renderer.dev.js",
    "test": "cross-env NODE_ENV=test BABEL_DISABLE_CACHE=1 jest",
    "test-all": "yarn lint && yarn ts && yarn build && yarn test",
    "test-watch": "yarn test --watch"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "{*.json,.{babelrc,eslintrc,prettierrc,stylelintrc}}": [
      "prettier --ignore-path .eslintignore --parser json --write"
    ],
    "*.{css,scss}": [
      "stylelint --ignore-path .eslintignore --syntax scss --fix",
      "prettier --ignore-path .eslintignore --single-quote --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .eslintignore --single-quote --write"
    ]
  },
  "build": {
    "productName": "timestep",
    "appId": "io.github.michaelsweeney.timestep",
    "files": [
      "dist/",
      "node_modules/",
      "app.html",
      "main.prod.js",
      "main.prod.js.map",
      "preload.js",
      "package.json"
    ],
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "michaelsweeney",
      "repo": "timestep",
      "private": false
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelsweeney/timestep.git"
  },
  "author": {
    "name": "Michael Sweeney",
    "email": "michael.samuel.sweeney@gmail.com",
    "url": "https://github.com/michaelsweeney"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/michaelsweeney/timestep/issues"
  },
  "keywords": [
    "energyplus",
    "timeseries",
    "visualization",
    "building-energy",
    "eso",
    "sqlite",
    "d3",
    "electron"
  ],
  "homepage": "https://github.com/michaelsweeney/timestep#readme",
  "jest": {
    "testURL": "http://localhost/",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/release/",
      "/.claude/",
      "/packages/"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/internals/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "app/node_modules"
    ],
    "setupFiles": [
      "./internals/scripts/CheckBuildsExist.js"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-proposal-decorators": "^7.24.0",
    "@babel/plugin-proposal-do-expressions": "^7.24.0",
    "@babel/plugin-proposal-export-default-from": "^7.24.0",
    "@babel/plugin-proposal-function-bind": "^7.24.0",
    "@babel/plugin-proposal-function-sent": "^7.24.0",
    "@babel/plugin-proposal-pipeline-operator": "^7.24.0",
    "@babel/plugin-proposal-throw-expressions": "^7.24.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/plugin-transform-react-constant-elements": "^7.24.0",
    "@babel/plugin-transform-react-inline-elements": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@babel/register": "^7.24.0",
    "@electron/rebuild": "^4.0.0",
    "@types/enzyme": "^3.10.5",
    "@types/enzyme-adapter-react-16": "^1.0.6",
    "@types/history": "^4.7.5",
    "@types/jest": "^24.9.1",
    "@types/node": "^20",
    "@types/react": "^16.9.17",
    "@types/react-dom": "^16.9.6",
    "@types/react-redux": "^7.1.6",
    "@types/react-router": "^5.1.5",
    "@types/react-router-dom": "^5.1.3",
    "@types/react-test-renderer": "^16.9.2",
    "@types/redux-logger": "^3.0.7",
    "@types/sinon": "^7.5.2",
    "@typescript-eslint/eslint-plugin": "^2.17.0",
    "@typescript-eslint/parser": "^2.17.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^25.1.0",
    "babel-loader": "^10.1.0",
    "babel-plugin-dev-expression": "^0.2.2",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "chalk": "^3.0.0",
    "concurrently": "^5.2.0",
    "cross-env": "^7.0.0",
    "cross-spawn": "^7.0.1",
    "css-loader": "^7.1.0",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "detect-port": "^1.3.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-devtools-installer": "^4.0.0",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.2",
    "enzyme-to-json": "^3.4.4",
    "eslint": "^6.8.0",
    "eslint-config-airbnb-typescript": "^6.3.1",
    "eslint-config-erb": "^0.3.0",
    "eslint-config-prettier": "^6.9.0",
    "eslint-import-resolver-webpack": "^0.12.1",
    "eslint-plugin-compat": "^3.5.1",
    "eslint-plugin-import": "^2.20.0",
    "eslint-plugin-jest": "^23.6.0",
    "eslint-plugin-jsx-a11y": "6.2.3",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.18.0",
    "eslint-plugin-react-hooks": "^2.3.0",
    "fbjs-scripts": "^1.2.0",
    "husky": "^4.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^25.1.0",
    "lint-staged": "^10.0.2",
    "mini-css-extract-plugin": "^2.10.0",
    "playwright-core": "^1.60.0",
    "prettier": "^1.19.1",
    "react-test-renderer": "^16.12.0",
    "redux-logger": "^3.0.6",
    "rimraf": "^3.0.0",
    "sass": "^1.77.0",
    "sass-loader": "^16.0.0",
    "sinon": "^8.1.1",
    "style-loader": "^4.0.0",
    "stylelint": "^13.0.0",
    "stylelint-config-prettier": "^8.0.1",
    "stylelint-config-standard": "^19.0.0",
    "terser-webpack-plugin": "^5.3.0",
    "tsx": "^4.19.0",
    "typed-css-modules-webpack-plugin": "^0.2.0",
    "typescript": "^5.9.0",
    "webpack": "^5.106.0",
    "webpack-bundle-analyzer": "^5.0.0",
