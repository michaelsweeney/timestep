  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^4",
    "@fontsource/jetbrains-mono": "^4",
    "@fontsource/roboto": "^4",
    "@fortawesome/fontawesome-free": "^5.13.0",
    "@reduxjs/toolkit": "^1.4.0",
    "@timestep/core": "link:./packages/core",
    "baseline-browser-mapping": "^2.10.27",
    "caniuse-lite": "^1.0.30001792",
    "connected-react-router": "^6.6.1",
    "core-js": "^3.6.4",
    "history": "^4.10.1",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-redux": "^7.2.1",
    "react-router": "^5.1.2",
    "react-router-dom": "^5.1.2",
    "react-sidebar": "^3.0.2",
    "react-virtualized": "^9.21.2",
    "react-window": "^1.8.5",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "reselect": "^4.0.0",
    "source-map-support": "^0.5.16",
    "sql.js": "^1.14.1",
    "sqlite3": "^5.1.7"
  },
  "browserslist": [
    "last 2 chrome versions"
  ],
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".babelrc",
          ".eslintrc",
          ".stylelintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "singleQuote": true
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard",
      "stylelint-config-prettier"
    ]
  }
}
